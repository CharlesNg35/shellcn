{
  "apiVersion": 1,
  "name": "docker",
  "version": "0.1.0",
  "title": "Docker",
  "description": "Docker host \u2014 containers, images, volumes, networks.",
  "icon": {
    "type": "emoji",
    "value": "\ud83d\udc33"
  },
  "category": {
    "key": "containers",
    "label": "Containers",
    "icon": { "type": "lucide", "value": "boxes" },
    "order": 30
  },
  "capabilities": ["containers", "images", "volumes", "networks"],
  "supportedTransports": ["direct", "agent"],
  "agent": {
    "modes": ["unix"],
    "riskNote": "Docker socket access is root-equivalent (privileged)."
  },
  "layout": "sidebar_tree",
  "config": {
    "groups": [
      {
        "name": "Endpoint",
        "fields": [
          {
            "key": "endpoint_type",
            "label": "Endpoint",
            "type": "select",
            "required": true,
            "default": "unix",
            "visibleWhen": {
              "allOf": [
                {
                  "field": "$transport",
                  "op": "eq",
                  "value": "direct"
                }
              ]
            },
            "options": [
              { "label": "Unix socket", "value": "unix" },
              { "label": "TCP host", "value": "tcp" }
            ]
          },
          {
            "key": "socket_path",
            "label": "Socket path",
            "type": "text",
            "required": true,
            "default": "/var/run/docker.sock",
            "visibleWhen": {
              "allOf": [
                {
                  "field": "$transport",
                  "op": "eq",
                  "value": "direct"
                },
                {
                  "field": "endpoint_type",
                  "op": "eq",
                  "value": "unix"
                }
              ]
            }
          },
          {
            "key": "host",
            "label": "Host",
            "type": "text",
            "required": true,
            "placeholder": "docker.example.internal",
            "visibleWhen": {
              "allOf": [
                {
                  "field": "$transport",
                  "op": "eq",
                  "value": "direct"
                },
                {
                  "field": "endpoint_type",
                  "op": "eq",
                  "value": "tcp"
                }
              ]
            }
          },
          {
            "key": "port",
            "label": "Port",
            "type": "number",
            "required": true,
            "default": 2375,
            "visibleWhen": {
              "allOf": [
                {
                  "field": "$transport",
                  "op": "eq",
                  "value": "direct"
                },
                {
                  "field": "endpoint_type",
                  "op": "eq",
                  "value": "tcp"
                }
              ]
            },
            "validators": [
              { "type": "min", "value": 1 },
              { "type": "max", "value": 65535 }
            ]
          }
        ]
      }
    ]
  },
  "tree": [
    {
      "key": "containers",
      "label": "Containers",
      "icon": {
        "type": "lucide",
        "value": "box"
      },
      "source": {
        "routeId": "docker.container.list"
      },
      "badge": {
        "source": {
          "routeId": "docker.container.count"
        },
        "severity": "info"
      }
    },
    {
      "key": "images",
      "label": "Images",
      "icon": {
        "type": "lucide",
        "value": "layers"
      },
      "source": {
        "routeId": "docker.image.list"
      }
    },
    {
      "key": "volumes",
      "label": "Volumes",
      "icon": {
        "type": "lucide",
        "value": "database"
      },
      "source": {
        "routeId": "docker.volume.list"
      }
    },
    {
      "key": "networks",
      "label": "Networks",
      "icon": {
        "type": "lucide",
        "value": "share"
      },
      "source": {
        "routeId": "docker.network.list"
      }
    }
  ],
  "resources": [
    {
      "kind": "container",
      "title": "Containers",
      "list": {
        "routeId": "docker.container.list"
      },
      "watch": {
        "routeId": "docker.container.watch",
        "method": "WS"
      },
      "columns": [
        {
          "key": "name",
          "label": "Name",
          "sortable": true
        },
        {
          "key": "image",
          "label": "Image"
        },
        {
          "key": "state",
          "label": "State",
          "type": "badge",
          "sortable": true
        },
        {
          "key": "status",
          "label": "Status"
        },
        {
          "key": "ports",
          "label": "Ports"
        }
      ],
      "actionIds": [
        "docker.container.start",
        "docker.container.stop",
        "docker.container.restart",
        "docker.container.remove"
      ],
      "detail": {
        "header": {
          "title": "${resource.name}",
          "statusField": "state",
          "actionIds": [
            "docker.container.start",
            "docker.container.stop",
            "docker.container.restart",
            "docker.container.remove"
          ]
        },
        "tabs": [
          {
            "key": "overview",
            "label": "Overview",
            "panel": "metrics",
            "source": {
              "routeId": "docker.container.stats",
              "method": "WS",
              "params": {
                "id": "${resource.uid}"
              }
            }
          },
          {
            "key": "terminal",
            "label": "Terminal",
            "panel": "terminal",
            "source": {
              "routeId": "docker.container.exec",
              "method": "WS",
              "params": {
                "id": "${resource.uid}"
              }
            }
          },
          {
            "key": "logs",
            "label": "Logs",
            "panel": "log_stream",
            "source": {
              "routeId": "docker.container.logs",
              "method": "WS",
              "params": {
                "id": "${resource.uid}"
              }
            }
          },
          {
            "key": "inspect",
            "label": "Inspect",
            "panel": "code_editor",
            "source": {
              "routeId": "docker.container.inspect",
              "params": {
                "id": "${resource.uid}"
              }
            },
            "config": {
              "language": "json",
              "readOnly": true
            }
          },
          {
            "key": "env",
            "label": "Env",
            "panel": "table",
            "source": {
              "routeId": "docker.container.env",
              "params": {
                "id": "${resource.uid}"
              }
            }
          }
        ]
      }
    }
  ],
  "actions": [
    {
      "id": "docker.container.start",
      "label": "Start",
      "icon": {
        "type": "lucide",
        "value": "play"
      },
      "routeId": "docker.container.start",
      "method": "POST",
      "params": {
        "id": "${resource.uid}"
      },
      "risk": "write",
      "requiresConfirm": false
    },
    {
      "id": "docker.container.stop",
      "label": "Stop",
      "icon": {
        "type": "lucide",
        "value": "square"
      },
      "routeId": "docker.container.stop",
      "method": "POST",
      "params": {
        "id": "${resource.uid}"
      },
      "risk": "write",
      "requiresConfirm": false
    },
    {
      "id": "docker.container.restart",
      "label": "Restart",
      "icon": {
        "type": "lucide",
        "value": "refresh-cw"
      },
      "routeId": "docker.container.restart",
      "method": "POST",
      "params": {
        "id": "${resource.uid}"
      },
      "risk": "write",
      "requiresConfirm": false
    },
    {
      "id": "docker.container.remove",
      "label": "Remove",
      "icon": {
        "type": "lucide",
        "value": "trash"
      },
      "routeId": "docker.container.remove",
      "method": "DELETE",
      "params": {
        "id": "${resource.uid}"
      },
      "risk": "destructive",
      "requiresConfirm": true,
      "confirmText": "Remove this container? This cannot be undone."
    }
  ],
  "streams": [
    {
      "id": "docker.container.logs",
      "kind": "logs",
      "routeId": "docker.container.logs"
    },
    {
      "id": "docker.container.exec",
      "kind": "terminal",
      "routeId": "docker.container.exec"
    },
    {
      "id": "docker.container.stats",
      "kind": "metrics",
      "routeId": "docker.container.stats"
    }
  ]
}
