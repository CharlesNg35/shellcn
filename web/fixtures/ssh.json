{
  "apiVersion": 1,
  "name": "ssh",
  "version": "0.1.0",
  "title": "SSH",
  "description": "Secure Shell — terminal, files, and command snippets.",
  "icon": { "type": "lucide", "value": "terminal" },
  "category": {
    "key": "shell",
    "label": "Shell & terminal",
    "icon": { "type": "lucide", "value": "terminal" },
    "order": 10
  },
  "capabilities": ["terminal", "filesystem"],
  "credentialKinds": [
    {
      "kind": "ssh_private_key",
      "label": "SSH private key",
      "secretLabel": "Private key",
      "secretMultiline": true,
      "identityLabel": "Username"
    },
    {
      "kind": "ssh_password",
      "label": "SSH password",
      "secretLabel": "Password",
      "identityLabel": "Username"
    }
  ],
  "supportedTransports": ["direct"],
  "layout": "tabs",
  "config": {
    "groups": [
      {
        "name": "Basic",
        "fields": [
          {
            "key": "host",
            "label": "Host",
            "type": "text",
            "required": true,
            "placeholder": "10.0.0.1"
          },
          {
            "key": "port",
            "label": "Port",
            "type": "number",
            "default": 22,
            "validators": [
              { "type": "min", "value": 1 },
              { "type": "max", "value": 65535 }
            ]
          },
          {
            "key": "user",
            "label": "Username",
            "type": "text",
            "required": true,
            "default": "root"
          }
        ]
      },
      {
        "name": "Auth",
        "fields": [
          {
            "key": "auth",
            "label": "Authentication",
            "type": "select",
            "required": true,
            "default": "password",
            "options": [
              { "label": "Password", "value": "password" },
              { "label": "Private key", "value": "private_key" },
              { "label": "Stored SSH password", "value": "stored_password" },
              {
                "label": "Stored SSH private key",
                "value": "stored_private_key"
              }
            ]
          },
          {
            "key": "credential_password_id",
            "label": "Stored SSH password",
            "type": "credential_ref",
            "credential": {
              "kind": "ssh_password",
              "protocols": ["ssh"],
              "required": true
            },
            "visibleWhen": {
              "allOf": [
                { "field": "auth", "op": "eq", "value": "stored_password" }
              ]
            }
          },
          {
            "key": "credential_private_key_id",
            "label": "Stored SSH private key",
            "type": "credential_ref",
            "credential": {
              "kind": "ssh_private_key",
              "protocols": ["ssh"],
              "required": true
            },
            "visibleWhen": {
              "allOf": [
                { "field": "auth", "op": "eq", "value": "stored_private_key" }
              ]
            }
          },
          {
            "key": "password",
            "label": "Password",
            "type": "password",
            "secret": true,
            "visibleWhen": {
              "allOf": [{ "field": "auth", "op": "eq", "value": "password" }]
            }
          },
          {
            "key": "private_key",
            "label": "Private key",
            "type": "textarea",
            "secret": true,
            "help": "PEM-encoded private key.",
            "visibleWhen": {
              "allOf": [{ "field": "auth", "op": "eq", "value": "private_key" }]
            }
          },
          {
            "key": "passphrase",
            "label": "Key passphrase",
            "type": "password",
            "secret": true,
            "visibleWhen": {
              "anyOf": [
                { "field": "auth", "op": "eq", "value": "private_key" },
                { "field": "auth", "op": "eq", "value": "stored_private_key" }
              ]
            }
          }
        ]
      }
    ]
  },
  "tabs": [
    {
      "key": "terminal",
      "label": "Terminal",
      "icon": { "type": "lucide", "value": "terminal" },
      "panel": "terminal",
      "source": { "routeId": "ssh.shell", "method": "WS" }
    },
    {
      "key": "files",
      "label": "Files",
      "icon": { "type": "lucide", "value": "folder" },
      "panel": "file_browser",
      "source": { "routeId": "ssh.sftp.list", "params": { "path": "." } },
      "config": {
        "pathParam": "path",
        "readRouteId": "ssh.sftp.read",
        "downloadRouteId": "ssh.sftp.download",
        "writeRouteId": "ssh.sftp.write",
        "uploadRouteId": "ssh.sftp.upload",
        "mkdirRouteId": "ssh.sftp.mkdir",
        "renameRouteId": "ssh.sftp.rename",
        "deleteRouteId": "ssh.sftp.delete",
        "writable": true,
        "multipleUpload": true,
        "maxUploadBytes": 52428800
      }
    },
    {
      "key": "snippets",
      "label": "Snippets",
      "icon": { "type": "lucide", "value": "code" },
      "panel": "table",
      "source": { "routeId": "ssh.snippet.list" },
      "config": {
        "columns": [
          { "key": "name", "label": "Name", "sortable": true },
          { "key": "body", "label": "Command" },
          {
            "key": "updatedAt",
            "label": "Updated",
            "type": "datetime",
            "sortable": true
          }
        ],
        "actionIds": ["ssh.snippet.create"],
        "rowActionIds": ["ssh.snippet.run", "ssh.snippet.delete"]
      }
    }
  ],
  "actions": [
    {
      "id": "ssh.snippet.create",
      "label": "New snippet",
      "icon": { "type": "lucide", "value": "plus" },
      "routeId": "ssh.snippet.create",
      "method": "POST",
      "risk": "write",
      "requiresConfirm": false,
      "input": {
        "groups": [
          {
            "name": "Snippet",
            "fields": [
              {
                "key": "name",
                "label": "Name",
                "type": "text",
                "required": true
              },
              {
                "key": "body",
                "label": "Command",
                "type": "textarea",
                "required": true
              }
            ]
          }
        ]
      }
    },
    {
      "id": "ssh.snippet.run",
      "label": "Run",
      "icon": { "type": "lucide", "value": "play" },
      "routeId": "ssh.snippet.run",
      "method": "POST",
      "params": { "id": "${resource.uid}" },
      "risk": "privileged",
      "requiresConfirm": true,
      "confirmText": "Run this snippet on the SSH host?",
      "onSuccess": { "selectTab": "terminal" }
    },
    {
      "id": "ssh.snippet.delete",
      "label": "Delete",
      "icon": { "type": "lucide", "value": "trash" },
      "routeId": "ssh.snippet.delete",
      "method": "DELETE",
      "params": { "id": "${resource.uid}" },
      "risk": "destructive",
      "requiresConfirm": true,
      "confirmText": "Delete this snippet?"
    }
  ],
  "streams": [{ "id": "ssh.shell", "kind": "terminal", "routeId": "ssh.shell" }]
}
