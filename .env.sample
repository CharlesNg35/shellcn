SHELLCN_SERVER_ADDR=":8081"
SHELLCN_SERVER_LOG_LEVEL=info

SHELLCN_AUTH_SESSION_TTL=24h
SHELLCN_AUTH_JWT_SECRET=

SHELLCN_BOOTSTRAP_ADMIN_USERNAME=admin
SHELLCN_BOOTSTRAP_ADMIN_PASSWORD=

SHELLCN_DATABASE_DRIVER=sqlite
SHELLCN_DATABASE_DSN=shellcn.db
# SHELLCN_DATABASE_DRIVER=postgres
# SHELLCN_DATABASE_DSN="host=localhost user=shellcn password=secret dbname=shellcn port=5432 sslmode=disable"
# SHELLCN_DATABASE_DRIVER=mysql
# SHELLCN_DATABASE_DSN="shellcn:secret@tcp(localhost:3306)/shellcn?charset=utf8mb4&parseTime=True&loc=Local"

SHELLCN_SECRETS_MASTER_KEY=
SHELLCN_SECRETS_MASTER_KEY_FILE=
SHELLCN_MASTER_KEY=
SHELLCN_MASTER_KEY_FILE=

SHELLCN_EMAIL_ENABLED=false
SHELLCN_EMAIL_HOST=smtp.example.com
SHELLCN_EMAIL_PORT=587
SHELLCN_EMAIL_FROM="ShellCN <shellcn@example.com>"
SHELLCN_EMAIL_USERNAME=shellcn@example.com
SHELLCN_EMAIL_PASSWORD=
SHELLCN_EMAIL_USE_TLS=false

# Shared AI is optional. Supported kinds: openrouter, openai, anthropic, google,
# openai_compatible. Users can also add personal providers in Settings.
# SHELLCN_AI_KIND=openrouter
# SHELLCN_AI_NAME="Shared OpenRouter"
# SHELLCN_AI_API_KEY=sk-or-v1-example
# SHELLCN_AI_DEFAULT_MODEL=openai/gpt-4o
# SHELLCN_AI_BASE_URL=

# OpenAI-compatible example.
# SHELLCN_AI_KIND=openai_compatible
# SHELLCN_AI_NAME="Shared Local AI"
# SHELLCN_AI_BASE_URL=http://127.0.0.1:11434/v1
# SHELLCN_AI_API_KEY=ollama
# SHELLCN_AI_DEFAULT_MODEL=llama3.1:8b

SHELLCN_RECORDINGS_DIR=recordings
SHELLCN_RECORDINGS_RETENTION_DAYS=0
SHELLCN_RECORDINGS_CLEANUP_INTERVAL=1h
SHELLCN_RECORDINGS_MAX_CHUNK_BYTES=8388608
