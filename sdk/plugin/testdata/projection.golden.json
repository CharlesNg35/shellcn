{
  "apiVersion": 1,
  "name": "sample",
  "version": "0.1.0",
  "title": "Sample",
  "description": "A representative plugin used by the golden test.",
  "icon": {
    "type": "svg",
    "value": "\u003csvg viewBox=\"0 0 1 1\"\u003e\u003c/svg\u003e"
  },
  "category": {
    "key": "shell",
    "label": "Shell \u0026 terminal",
    "icon": {
      "type": "lucide",
      "value": "terminal"
    },
    "order": 10
  },
  "config": {
    "groups": [
      {
        "name": "Basic",
        "fields": [
          {
            "key": "host",
            "label": "Host",
            "type": "text",
            "required": true,
            "placeholder": "10.0.0.1"
          },
          {
            "key": "port",
            "label": "Port",
            "type": "number",
            "default": 22,
            "validators": [
              {
                "type": "min",
                "value": 1
              },
              {
                "type": "max",
                "value": 65535
              }
            ]
          },
          {
            "key": "password",
            "label": "Password",
            "type": "password",
            "secret": true,
            "visibleWhen": {
              "allOf": [
                {
                  "field": "auth",
                  "op": "eq",
                  "value": "password"
                }
              ]
            }
          },
          {
            "key": "credential_id",
            "label": "Credential",
            "type": "credential_ref",
            "credential": {
              "kind": "sample_private_key",
              "protocols": [
                "ssh"
              ],
              "required": true
            }
          }
        ]
      }
    ]
  },
  "capabilities": [
    "terminal",
    "filesystem"
  ],
  "credentialKinds": [
    {
      "kind": "sample_private_key",
      "label": "Sample private key",
      "secretLabel": "Private key",
      "secretMultiline": true,
      "identityLabel": "Username"
    }
  ],
  "supportedTransports": [
    "direct"
  ],
  "layout": "sidebar_tree",
  "tabs": [
    {
      "key": "terminal",
      "label": "Terminal",
      "icon": {
        "type": "lucide",
        "value": "terminal"
      },
      "panel": "terminal",
      "source": {
        "routeId": "sample.shell",
        "method": "WS"
      }
    },
    {
      "key": "files",
      "label": "Files",
      "icon": {
        "type": "lucide",
        "value": "folder"
      },
      "panel": "file_browser",
      "source": {
        "routeId": "sample.files.list",
        "params": {
          "path": "/"
        }
      },
      "config": {
        "pathParam": "path",
        "readRouteId": "sample.files.read",
        "downloadRouteId": "sample.files.download",
        "uploadRouteId": "sample.files.upload",
        "mkdirRouteId": "sample.files.mkdir",
        "renameRouteId": "sample.files.rename",
        "deleteRouteId": "sample.files.delete",
        "writable": true,
        "multipleUpload": true
      }
    }
  ],
  "tree": [
    {
      "key": "containers",
      "label": "Containers",
      "source": {
        "routeId": "sample.list"
      },
      "resourceKind": "container"
    }
  ],
  "resources": [
    {
      "kind": "container",
      "title": "Containers",
      "list": {
        "routeId": "sample.list"
      },
      "columns": [
        {
          "key": "name",
          "label": "Name",
          "sortable": true,
          "type": "text"
        }
      ],
      "actions": {
        "detail": [
          "sample.start"
        ]
      },
      "detail": {
        "header": {
          "title": "Container"
        },
        "defaultTab": "editor",
        "tabs": [
          {
            "key": "logs",
            "label": "Logs",
            "panel": "log_stream",
            "source": {
              "routeId": "sample.logs",
              "method": "WS"
            }
          },
          {
            "key": "summary",
            "label": "Summary",
            "panel": "object_detail",
            "source": {
              "routeId": "sample.summary"
            },
            "config": {
              "sections": [
                {
                  "title": "Usage",
                  "fields": [
                    {
                      "key": "memoryPct",
                      "label": "Memory",
                      "type": "percent",
                      "usage": {
                        "percentKey": "memoryPct",
                        "usedKey": "memoryUsed",
                        "totalKey": "memoryTotal",
                        "usedType": "bytes",
                        "totalType": "bytes",
                        "warnAt": 80,
                        "criticalAt": 95
                      }
                    }
                  ]
                }
              ]
            }
          },
          {
            "key": "config",
            "label": "Config",
            "panel": "form",
            "source": {
              "routeId": "sample.form"
            },
            "config": {
              "submitRouteId": "sample.form.save",
              "submitMethod": "PATCH",
              "submitLabel": "Apply",
              "params": {
                "id": "${resource.uid}"
              }
            }
          },
          {
            "key": "editor",
            "label": "Editor",
            "panel": "code_editor",
            "source": {
              "routeId": "sample.doc"
            },
            "config": {
              "language": "yaml",
              "saveRouteId": "sample.doc.save",
              "saveMethod": "PUT",
              "saveParams": {
                "id": "${resource.uid}"
              }
            }
          },
          {
            "key": "query",
            "label": "Query",
            "panel": "query_editor",
            "source": {
              "routeId": "sample.query",
              "method": "WS"
            },
            "config": {
              "initialQuery": "select * from ${resource.name} limit 100",
              "cancelRouteId": "sample.query.cancel"
            }
          }
        ]
      }
    }
  ],
  "actions": [
    {
      "id": "sample.start",
      "label": "Start",
      "icon": {
        "type": "lucide",
        "value": "play"
      },
      "routeId": "sample.start",
      "method": "POST",
      "risk": "write",
      "requiresConfirm": true,
      "confirmText": "Start it?",
      "input": {
        "groups": [
          {
            "name": "opts",
            "fields": [
              {
                "key": "force",
                "label": "Force",
                "type": "toggle"
              }
            ]
          }
        ]
      },
      "enabledWhen": {
        "allOf": [
          {
            "field": "state",
            "op": "eq",
            "value": "stopped"
          }
        ]
      }
    }
  ],
  "streams": [
    {
      "id": "sample.shell",
      "kind": "terminal",
      "routeId": "sample.shell"
    },
    {
      "id": "sample.logs",
      "kind": "logs",
      "routeId": "sample.logs"
    }
  ],
  "recording": [
    {
      "class": "terminal",
      "formats": [
        "asciicast_v2"
      ],
      "authoritative": true,
      "inputCapture": false
    }
  ],
